# Google Drive sync configuration (optional)
# Set GOOGLE_DRIVE_ENABLED=true to activate synchronization.
GOOGLE_DRIVE_ENABLED=false

# Local output folder for automatic sync via Google Drive Desktop (recommended simple mode).
# Example (Windows): G:\\Mon Drive\\DSKT
LOCAL_RESULTS_DIR=
LOCAL_RESULTS_FILE_NAME=examen_resultat.csv

# Absolute path to your service account JSON file (do not commit real credentials).
# Example (Windows): C:\\path\\to\\service-account.json
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=

# Alternative for Streamlit Cloud: full JSON content of the service account
# as a single line or a TOML multiline string in secrets.
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Target folder ID in Google Drive (optional but recommended).
# Example: 1cvAmxJ7iplbKRsVwOkkwBnVZQ4Xjzu-9
GOOGLE_DRIVE_FOLDER_ID="1cvAmxJ7iplbKRsVwOkkwBnVZQ4Xjzu-9"

# Target filename in Google Drive.
GOOGLE_DRIVE_FILE_NAME=examen_resultat.csv

# Google Sheets via Apps Script webhook (recommended alternative)
GOOGLE_SHEETS_WEBHOOK_ENABLED=false
GOOGLE_SHEETS_WEBHOOK_URL=
